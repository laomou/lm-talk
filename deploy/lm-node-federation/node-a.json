{
  "bind": "0.0.0.0:8787",
  "peer_id": "lm-node-a",
  "state_db": "/data/lm-node.sqlite3",
  "state_db_encryption_mode": "external",
  "state_db_require_encryption": true,
  "state_file": "/data/lm-node-state.json",
  "state_file_passphrase_file": "/run/secrets/state-file-passphrase-a",
  "state_file_require_encryption": true,
  "control_token_file": "/run/secrets/node-a-token",
  "cors_allow_origins": ["http://localhost:5173"],
  "log_format": "json",
  "dht_transport": "http",
  "dht_replication_factor": 3,
  "dht_routing_refresh_limit": 8,
  "dht_routing_refresh_max_targets": 8,
  "sync_interval_seconds": 30,
  "sync_max_backoff_seconds": 300,
  "max_mailbox_bytes_per_user": 10485760,
  "max_mailbox_messages_per_user": 1000,
  "sync_peers": [
    { "url": "http://caddy-b", "peer_id": "lm-node-b", "token_file": "/run/secrets/node-b-token" },
    { "url": "http://caddy-c", "peer_id": "lm-node-c", "token_file": "/run/secrets/node-c-token" }
  ]
}
