{
  "bind": "0.0.0.0:8787",
  "peer_id": "lm-node-public-1",
  "state_db": "/data/lm-node.sqlite3",
  "control_token_file": "/run/secrets/control-token",
  "cors_allow_origins": [
    "https://YOUR_GITHUB_USER.github.io"
  ],
  "log_format": "json",
  "dht_transport": "http",
  "dht_replication_factor": 3,
  "dht_routing_refresh_limit": 8,
  "dht_routing_refresh_max_targets": 8,
  "dht_peer_quarantine_consecutive_failures": 3,
  "sync_interval_seconds": 60,
  "sync_max_backoff_seconds": 600,
  "rate_limit_window_seconds": 60,
  "rate_limit_max_requests": 600,
  "mailbox_sender_rate_limit_window_seconds": 60,
  "mailbox_sender_rate_limit_max_messages": 120,
  "mailbox_global_rate_limit_window_seconds": 60,
  "mailbox_global_rate_limit_max_messages": 1200,
  "max_mailbox_bytes": 1073741824,
  "max_mailbox_bytes_per_user": 10485760,
  "max_mailbox_messages_per_user": 1000,
  "sync_peers": []
}
